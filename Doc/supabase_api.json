  "definitions": {
    "song_artists": {
      "description": "關聯表：紀錄歌曲與歌手的多對多關係。",
      "required": [
        "song_id",
        "artist_id"
      ],
      "properties": {
        "song_id": {
          "description": "客觀歌曲主檔 ID。\nNote:\nThis is a Primary Key.<pk/>\nThis is a Foreign Key to `songs.song_id`.<fk table='songs' column='song_id'/>",
          "format": "uuid",
          "type": "string"
        },
        "artist_id": {
          "description": "歌手主檔 ID。\nNote:\nThis is a Primary Key.<pk/>\nThis is a Foreign Key to `artists.artist_id`.<fk table='artists' column='artist_id'/>",
          "format": "uuid",
          "type": "string"
        }
      },
      "type": "object"
    },
    "songs": {
      "description": "客觀歌曲主檔。僅紀錄不可變之音樂客觀資訊 (如原調、BPM、發行資訊)。不包含任何個人自訂值。",
      "required": [
        "song_id",
        "name"
      ],
      "properties": {
        "song_id": {
          "default": "gen_random_uuid()",
          "description": "系統內部自動生成的唯一識別碼 (UUID)。不使用 ISRC 作為主鍵，以確保無 ISRC 的地下/原創音樂也能建檔，並維持系統所有關聯紀錄不可變。\nNote:\nThis is a Primary Key.<pk/>",
          "format": "uuid",
          "type": "string"
        },
        "name": {
          "description": "歌曲名稱 (例如：告白氣球)。",
          "format": "text",
          "type": "string"
        },
        "genre_id": {
          "description": "曲風分類代碼。",
          "format": "integer",
          "type": "integer"
        },
        "isrc": {
          "description": "國際標準錄音代碼。作為獨立的唯一欄位，專職處理對外平台 (如 Spotify、Apple Music) 的資料比對，防止具備 ISRC 的商業歌曲被重複寫入。",
          "format": "text",
          "type": "string"
        },
        "external_ids": {
          "description": "外部串流平台的 ID 集合。格式為 JSONB，例如: {\"spotify\": \"46gOuHGsd3...\"}。",
          "format": "jsonb"
        },
        "chord_link": {
          "description": "外部和弦譜或樂譜連結。",
          "format": "text",
          "type": "string"
        },
        "medias": {
          "description": "相關媒體資源 (如 YouTube 連結或音檔 URL) 陣列。",
          "format": "text[]",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "key": {
          "description": "客觀的歌曲原調 (例如: C Major)。若要存取使用者的主觀轉調設定，請參考 user_songs 表格中的 user_key。",
          "format": "text",
          "type": "string"
        },
        "bpm": {
          "description": "歌曲的客觀速度 (Tempo)。",
          "format": "integer",
          "type": "integer"
        },
        "release_date": {
          "description": "發行日期。Spotify 回傳格式可能為精確日期 (YYYY-MM-DD) 或僅有年份 (YYYY)。",
          "format": "date",
          "type": "string"
        }
      },
      "type": "object"
    },
    "artists": {
      "description": "歌手/樂團主檔。",
      "required": [
        "artist_id",
        "name"
      ],
      "properties": {
        "artist_id": {
          "default": "gen_random_uuid()",
          "description": "Note:\nThis is a Primary Key.<pk/>",
          "format": "uuid",
          "type": "string"
        },
        "name": {
          "description": "歌手或樂團名稱。",
          "format": "text",
          "type": "string"
        },
        "external_ids": {
          "description": "外部平台的歌手 ID (例如 Spotify Artist ID)，格式為 JSONB。",
          "format": "jsonb"
        }
      },
      "type": "object"
    },
    "users": {
      "description": "使用者資料表。",
      "required": [
        "user_id",
        "name"
      ],
      "properties": {
        "user_id": {
          "description": "使用者的唯一識別碼 (與 Supabase Auth 系統綁定)。\nNote:\nThis is a Primary Key.<pk/>",
          "format": "uuid",
          "type": "string"
        },
        "name": {
          "description": "使用者名稱或暱稱。",
          "format": "text",
          "type": "string"
        },
        "social": {
          "description": "社群連結或個人資訊 (JSONB)。",
          "format": "jsonb"
        }
      },
      "type": "object"
    },
    "user_songs": {
      "description": "使用者個人歌單與主觀設定關聯表。所有與特定使用者相關的偏好 (轉調、筆記、角色) 皆記錄於此。",
      "required": [
        "user_song_id",
        "status_id"
      ],
      "properties": {
        "user_song_id": {
          "default": "gen_random_uuid()",
          "description": "此筆個人歌單紀錄的唯一識別碼。\nNote:\nThis is a Primary Key.<pk/>",
          "format": "uuid",
          "type": "string"
        },
        "user_id": {
          "description": "綁定之使用者 ID。\nNote:\nThis is a Foreign Key to `users.user_id`.<fk table='users' column='user_id'/>",
          "format": "uuid",
          "type": "string"
        },
        "song_id": {
          "description": "關聯之客觀歌曲主檔 ID。\nNote:\nThis is a Foreign Key to `songs.song_id`.<fk table='songs' column='song_id'/>",
          "format": "uuid",
          "type": "string"
        },
        "user_key": {
